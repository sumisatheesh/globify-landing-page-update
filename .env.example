# Copy this file to .env.local (which is git-ignored) and fill in the values.

# --- Enquiry form email delivery (Resend) ---
# Sign up at https://resend.com, create an API key, and paste it here.
# Without this key, enquiries still submit successfully (the visitor sees a
# confirmation) and are logged to the server console as a fallback.
RESEND_API_KEY=

# The "from" address for outgoing enquiry emails to sales. Until you verify the
# globify.in domain in Resend, leave this blank to fall back to Resend's
# built-in onboarding@resend.dev sender. Once verified, set this to
# something like: "Globify Enquiries <noreply@globify.in>"
RESEND_FROM_EMAIL=

# The "from" address for acknowledgment emails sent to customers. Once domain is
# verified in Resend, set this to: "Globify <noreply@globify.in>"
RESEND_NOREPLY_EMAIL=

# The recipient address for all sales enquiries.
SALES_EMAIL=

